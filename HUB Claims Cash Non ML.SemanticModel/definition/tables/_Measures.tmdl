	measure '% Within 5 days YTD' =
			
			// Average TAT for claims closed month-to-date
			// Uses Modification Date (when claim was closed)
			VAR today = TODAY()
			VAR CurrentYear = YEAR(TODAY())
			
			RETURN
			CALCULATE(
			    [% Within 5 Days],
			    MedNext[Modification Date] >= DATE(CurrentYear, 1, 1),
			    MedNext[Modification Date] <= TODAY()
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: ⏱️ TAT Metrics
		lineageTag: 031ce836-c609-439f-b545-d219c1c428b0

	measure '% Within 5 days LM' =
			
			// Average TAT for claims closed month-to-date
			// Uses Modification Date (when claim was closed)
			var _currmomnth = MONTH(TODAY())
			var _curryear= SWITCH(TRUE(),_currmomnth=1,YEAR(TODAY())-1,YEAR(TODAY()))
			var _lastmonth = SWITCH(TRUE(),_currmomnth=1,12,_currmomnth-1)
			
			RETURN
			CALCULATE(
			    [% Within 5 Days],
			    MONTH(MedNext[Modification Date]) = _lastmonth,
			    YEAR(MedNext[Modification Date])= _curryear
			
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: ⏱️ TAT Metrics
		lineageTag: 051d6ac1-3d23-4181-8135-97a786b0fe28

	measure 'Avg TAT Date SVG' =
			
			
			VAR MAXPlan = 0
			VAR MAXActual = [Average TAT (Working Days)]
			VAR MAXTarget = 5
			VAR AXISRANGE = MAXX(
			    {
			        MAXPlan,
			        MAXActual,
			        MAXTarget
			    },
			    [Value]
			)
			VAR TRACKWIDTH = MAXPlan/AXISRANGE*100
			VAR PERCENTAGEFILL = MAXActual/AXISRANGE*100
			VAR PERCENTAGETARGET = MAXTarget/AXISRANGE*100
			RETURN
			IF((HASONEVALUE('Report Date Calendar'[Year])&&HASONEVALUE('Report Date Calendar'[Quarter])&&HASONEVALUE('Report Date Calendar'[Month Name])&&HASONEVALUE('Report Date Calendar'[Month Number])),
			"data:image/svg+xml;utf8," & "
			    <svg width='100' height='20' viewBox='-2 -2 102 22' xmlns='http://www.w3.org/2000/svg' xmlns:xlink='http://www.w3.org/1999/xlink' overflow='visible'>
			        <rect id='track' x='0' y='2' width='"&TRACKWIDTH&"' height='18' fill='green'/>
			        <rect id='fill' x='0' y='6' width="& "'"& PERCENTAGEFILL &"'"&" height='10' fill='green'></rect>
			        <rect id='marker' x="&"'"&PERCENTAGETARGET&"'"&" y='1' width='2' height='20' fill='orange'></rect>
			    </svg>
			", BLANK())
		displayFolder: ⏱️ TAT Metrics;SVGs
		lineageTag: 42bb4559-6dc0-49ba-a3bc-4a2738c7ad21
		dataCategory: ImageUrl

