	measure 'Avg Claims Processed/Day YTD' = ```
			
			VAR YTDDays = 
			    FILTER(
			        ALL('Calendar'),
			        'Calendar'[Date] >= DATE(YEAR(TODAY()), 1, 1) &&
			        'Calendar'[Date] <= TODAY() &&
			        NOT('Calendar'[Is UAE Holiday])&&
			        NOT('Calendar'[Is Weekend])
			
			    )
			VAR DailyProcessed = 
			    ADDCOLUMNS(
			        YTDDays,
			        "DailyClaims", CALCULATE([Claims Processed],USERELATIONSHIP('Calendar'[Date],MedNext[All Report Date]))
			    )
			RETURN
			    AVERAGEX(DailyProcessed, [DailyClaims])
