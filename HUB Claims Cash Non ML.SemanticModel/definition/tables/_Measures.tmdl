	measure 'Avg Claims Received Last 4 Same Weekday' = ```
			
			var CalTabl = 
			SUMMARIZE(
			        FILTER(
			            'Calendar',
			            'Calendar'[Date] >= TODAY() - 30
			            && 'Calendar'[Date] <= TODAY() 
			            && 'Calendar'[Is Weekend] = FALSE()
			            && 'Calendar'[Is UAE Holiday] = FALSE() 
						&& 'Calendar'[Weekday Number] = WEEKDAY(TODAY())
			        ),
			        'Calendar'[Date],
			        "Received Volume", [Claims Received]
			    )
			VAR CalAvg = AVERAGEX(CalTabl,[Received Volume])
			RETURN "Avg/day Last 4 "&FORMAT(TODAY(),"dddd")&"s: "&FORMAT(CalAvg,"#,##")
			```
		displayFolder: 📊 Volume Metrics
		lineageTag: deddbce5-e327-42c6-a437-ebe24f6acdda

