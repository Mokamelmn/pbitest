	measure 'Avg TAT LM' =
			
			var _currmomnth = MONTH(TODAY())
			var _curryear= SWITCH(TRUE(),_currmomnth=1,YEAR(TODAY())-1,YEAR(TODAY()))
			var _lastmonth = SWITCH(TRUE(),_currmomnth=1,12,_currmomnth-1)
			RETURN
			SUMMARIZE(
				FILTER(
					'Calendar',
					'Calendar'[Year]=_curryear&&'Calendar'[Month Number]=_lastmonth),
				"TATcol",[Average TAT (Working Days)]
			)
		displayFolder: ⏱️ TAT Metrics
