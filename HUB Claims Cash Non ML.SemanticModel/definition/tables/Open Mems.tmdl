	column 'Esraa Batchlist Label' =
			
			SWITCH(
			    TRUE(),
			    'Open Mems'[Esraa Batchlist.Batch Status] = "New","New",
			    ISBLANK('Open Mems'[Esraa Batchlist.Batch Status]) ,"New",
			    'Open Mems'[Esraa Batchlist.Batch Status] = "Reported/Closed","Done",
			    'Open Mems'[Esraa Batchlist.Batch Status] = "Cancelled","Done",
			    "Pending"
			)
