	partition 'Open Mems' = m
		mode: import
		source = ```
				let
				    // Step 1: Connect to SharePoint and get all files
				    Source = SharePoint.Contents("https://mednetuaefz-my.sharepoint.com/personal/mokamel_mednet_com1/", [ApiVersion = 15]),
				    // Step 1: Connect to SharePoint and get all files
				    Documents = Source{[Name="Documents"]}[Content],
				    // Step 1: Connect to SharePoint and get all files
				    #"HUB Cash Claims Non ML" = Documents{[Name="HUB Cash Claims Non ML"]}[Content],
				    // Step 1: Connect to SharePoint and get all files
				    Mems1 = #"HUB Cash Claims Non ML"{[Name="Mems"]}[Content],
				    #"Filtered Hidden Files1" = Table.SelectRows(Mems1, each [Attributes]?[Hidden]? <> true),
				    #"Invoke Custom Function1" = Table.AddColumn(#"Filtered Hidden Files1", "Transform File (6)", each #"Transform File (6)"([Content])),
				    #"Renamed Columns1" = Table.RenameColumns(#"Invoke Custom Function1", {"Name", "Source.Name"}),
				    #"Removed Other Columns1" = Table.SelectColumns(#"Renamed Columns1", {"Source.Name", "Transform File (6)"}),
				    #"Expanded Table Column1" = Table.ExpandTableColumn(#"Removed Other Columns1", "Transform File (6)", Table.ColumnNames(#"Transform File (6)"(#"Sample File (6)"))),
				    // Step 8: Set correct data types for all columns
				    #"Changed Type" = Table.TransformColumnTypes(#"Expanded Table Column1",{
				        {"Source.Name", type text}, 
				        {"Batch Number", Int64.Type}, 
				        {"Provider Id", type any}, 
				        {"Provider Name", type any}, 
				        {"PIC Code", Int64.Type}, 
				        {"PIC Name", type text}, 
				        {"Received Date", type date}, 
				        {"Invoice Count", Int64.Type}, 
				        {"Created By", type text}, 
				        {"Created Date", type date}, 
				        {"Submission Method  ", type text}, 
				        {"Submitted By", type text}, 
				        {"Provider Category", type text}, 
				        {"Prdefined Text Type", type text}, 
				        {"Batches External Reference", type text}, 
				        {"Notes", type text}, 
				        {"Net Claimed", type number}, 
				        {"Batch Status", type text}, 
				        {"Batch Categorie", type text}
				    }),
				    
				    // Step 9: Left join with Esraa Batchlist table to get additional batch status
				    #"Merged Queries" = Table.NestedJoin(#"Changed Type", {"Batch Number"}, #"Esraa Batchlist", {"Batch NO."}, "Esraa Batchlist", JoinKind.LeftOuter),
				    
				    // Step 10: Expand the Batch Status column from Esraa Batchlist
				    #"Expanded Esraa Batchlist" = Table.ExpandTableColumn(#"Merged Queries", "Esraa Batchlist", {"Batch Status"}, {"Esraa Batchlist.Batch Status"}),
				    
				    // Step 11: Group by Batch Number to handle duplicates across multiple files
				    // Each batch may appear in multiple files with different statuses
				    #"Grouped Rows" = Table.Group(#"Expanded Esraa Batchlist", {"Batch Number"}, {{"AllRows", each _, type table}}),
				    
				    // Step 12: FIX - Get the LATEST record for each batch by sorting by Source.Name (file name) in descending order
				    // Since file names follow format: Mems_createdbatches_YYYYMMDD-YYYYMMDD
				    // The most recent file will have the highest date and will sort last alphabetically
				    #"Added Custom" = Table.AddColumn(#"Grouped Rows", "LatestRow", each Table.First(Table.Sort([AllRows], {{"Source.Name", Order.Descending}}))),
				    
				    // Step 13: Remove the AllRows column as we only need the LatestRow
				    #"Removed Columns" = Table.RemoveColumns(#"Added Custom",{"AllRows"}),
				    
				    // Step 14: Expand all columns from the LatestRow record back into the table
				    #"Expanded LatestRow" = Table.ExpandRecordColumn(#"Removed Columns", "LatestRow", {
				        "Source.Name", "Provider Id", "Provider Name", "PIC Code", "PIC Name", "Received Date", 
				        "Invoice Count", "Created By", "Created Date", "Submission Method  ", "Submitted By", 
				        "Provider Category", "Prdefined Text Type", "Batches External Reference", "Notes", 
				        "Net Claimed", "Batch Status", "Batch Categorie", "Esraa Batchlist.Batch Status"
				    }, {
				        "Source.Name", "Provider Id", "Provider Name", "PIC Code", "PIC Name", "Received Date", 
				        "Invoice Count", "Created By", "Created Date", "Submission Method  ", "Submitted By", 
				        "Provider Category", "Prdefined Text Type", "Batches External Reference", "Notes", 
				        "Net Claimed", "Batch Status", "Batch Categorie", "Esraa Batchlist.Batch Status"
				    }),
				    
				    // Step 15: Keep only the columns we need for further analysis
				    #"Removed Other Columns" = Table.SelectColumns(#"Expanded LatestRow",{
				        "Batch Number", "Source.Name", "PIC Code", "Received Date", "Created By", "Created Date", 
				        "Prdefined Text Type", "Batches External Reference", "Notes", "Batch Status", "Esraa Batchlist.Batch Status"
				    }),
				    
				    // Step 16: Filter to show only batches with "Open" status (from the most recent file)
				    #"Filtered Rows2" = Table.SelectRows(#"Removed Other Columns", each ([Batch Status] = "Open")),
				    
				    // Step 19: Exclude specific PIC Codes that should not be included in the analysis
				    // These are likely specific providers or facilities that are handled separately
				    Custom1 = Table.SelectRows(#"Filtered Rows2", each (
				        [PIC Code] <> 214 and
				        [PIC Code] <> 539 and
				        [PIC Code] <> 259 and
				        [PIC Code] <> 278 and
				        [PIC Code] <> 444 and 
				        [PIC Code] <> 462 and 
				        [PIC Code] <> 209 and 
				        [PIC Code] <> 487 and 
				        [PIC Code] <> 433 and
				        [PIC Code] <> 449 and
				        [PIC Code] <> 137 and
				        [PIC Code] <> 435 and
				        [PIC Code] <> 301 and
				        [PIC Code] <> 368 and
				        [PIC Code] <> 501
				    )),
				    
				    // Step 20: Ensure Received Date is in the correct date format
				    #"Changed Type1" = Table.TransformColumnTypes(Custom1,{{"Received Date", type date}}),
				    
				    // Step 21: Left join with Archived table to check if batch has been archived
				    #"Merged Queries2" = Table.NestedJoin(#"Changed Type1", {"Batch Number"}, Archieved, {"Batch Number"}, "Archieved", JoinKind.LeftOuter),
				    
				    // Step 22: Expand the Batch Number from Archived table
				    #"Expanded Archieved" = Table.ExpandTableColumn(#"Merged Queries2", "Archieved", {"Batch Number"}, {"Archieved.Batch Number"}),
				    
				    // Step 23: Final filter - Keep only batches that are NOT in the Archived table (null = not archived)
				    // This ensures we only show active, open batches that haven't been archived
				    #"Filtered Rows1" = Table.SelectRows(#"Expanded Archieved", each ([Archieved.Batch Number] = null) )
				in
				    #"Filtered Rows1"
				```

	annotation PBI_NavigationStepName = Navigation

