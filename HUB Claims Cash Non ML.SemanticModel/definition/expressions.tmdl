expression 'Transform Sample File' = ```
		let
		    Source = Excel.Workbook(Parameter1, null, true),
		    Sheet1_Sheet = Source{[Item="Sheet1",Kind="Sheet"]}[Data],
		    // Clean invisible characters from headers BEFORE promoting
		    CleanHeaders = Table.TransformColumnNames(
		        Sheet1_Sheet,
		        each Text.Clean(Text.Trim(
		            Text.Replace(
		                Text.Replace(
		                    Text.Replace(_, 
		                        Character.FromNumber(8203), ""),  // Zero-width space
		                    Character.FromNumber(160), " "),      // Non-breaking space
		                Character.FromNumber(65279), "")          // BOM
		        ))
		    ),
		    
		    #"Promoted Headers" = Table.PromoteHeaders(CleanHeaders, [PromoteAllScalars=true]),
		    
		    // Additional cleanup AFTER promotion (double safety)
		    FinalClean = Table.TransformColumnNames(#"Promoted Headers", 
		        each Text.Clean(Text.Trim(
		            Text.Replace(
		                Text.Replace(
		                    Text.Replace(_, 
		                        Character.FromNumber(8203), ""),
		                    Character.FromNumber(160), " "),
		                Character.FromNumber(65279), "")
		        ))
		    )
		in
		    FinalClean
		```
